# AuthLens backend configuration — copy to `.env` and fill in.
# Load it when starting the server:
#   uv run uvicorn app.main:app --env-file .env --port 8000
# (`.env` is gitignored — never commit a real key.)

# --- LLM provider (Anthropic) ---------------------------------------------
# Paste your key to run the real LLM pipeline (live mode). Leave blank to run
# the deterministic demo (set DEMO_MODE=1 below).
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional model override (default: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Provider mode --------------------------------------------------------
# Resolution: DEMO_MODE truthy -> deterministic; AUTHLENS_LLM_MODE wins next;
# otherwise live iff a key is present, else deterministic. No hidden fallback:
# requesting live without a key fails at startup.
#
# Reproducible, no-network demo (no key required):
# DEMO_MODE=1
# Force live (errors at startup if ANTHROPIC_API_KEY is missing):
# AUTHLENS_LLM_MODE=live

# --- CORS (frontend dev origins; comma-separated) -------------------------
# Defaults already include Vite ports 5173/5175/5176 and CRA 3000.
# AUTHLENS_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
